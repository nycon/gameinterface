# =============================================================================
# GamePanel — Docker Compose Panel Stack
# Kopieren nach .env und Werte anpassen: cp .env.example .env
# Oder: ./install.sh --role panel-local
# =============================================================================

COMPOSE_PROJECT_NAME=gamepanel
APP_NAME=GamePanel
APP_ENV=local
APP_DEBUG=true
APP_KEY=
APP_URL=http://localhost:8080

PANEL_DOMAIN=localhost
SSL_MODE=selfsigned
SSL_EMAIL=admin@gamepanel.local

HTTP_PORT=8080
HTTPS_PORT=8443

POSTGRES_DB=gamepanel
POSTGRES_USER=gamepanel
POSTGRES_PASSWORD=changeme_generate_strong_secret
POSTGRES_PORT=5432

REDIS_PASSWORD=changeme_generate_strong_secret
REDIS_PORT=6379
REDIS_HOST=redis

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=gamepanel
DB_USERNAME=gamepanel
DB_PASSWORD=changeme_generate_strong_secret

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
LOG_CHANNEL=stack
LOG_LEVEL=debug

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=gamepanel
REVERB_APP_KEY=gamepanel-key
REVERB_APP_SECRET=gamepanel-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY=gamepanel-key
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

BACKEND_IMAGE=gamepanel-backend:local
FRONTEND_IMAGE=gamepanel-frontend:local

WORKER_PROCESSES=2
SCHEDULER_ENABLED=true
RUN_SEED=true

GAMEPANEL_ADMIN_EMAIL=admin@gamepanel.local
GAMEPANEL_ADMIN_PASSWORD=ChangeMe!2026

# VM1 — Panel
# Nicht manuell pflegen — lieber Flags:
#   sudo ./install.sh --role panel --non-interactive \
#     --domain panel.example.com --ssl-mode selfsigned \
#     --admin-email admin@example.com --admin-password 'StrongPass!2026' \
#     --image-server-host 10.0.0.11
#
# Diese Datei wird vom Installer nach /etc/gamepanel/installer.env geschrieben.

GP_ROLE=panel
GP_NON_INTERACTIVE=1
GAMEPANEL_SOURCE_DIR=/opt/gamepanel-src
PANEL_DOMAIN=panel.example.com
APP_URL=https://panel.example.com
SSL_MODE=selfsigned
SSL_EMAIL=admin@example.com
GAMEPANEL_ADMIN_EMAIL=admin@example.com
# GAMEPANEL_ADMIN_PASSWORD=  # leer = Installer generiert
IMAGE_SERVER_HOST=10.0.0.11
RUN_SEED=true
HTTP_PORT=80
HTTPS_PORT=443

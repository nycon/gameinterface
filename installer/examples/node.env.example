# VM3 — Game-Node
# Empfohlen ohne manuelle .env:
#   scp root@PANEL:/etc/gamepanel/node-join.env /tmp/node-join.env
#   sudo ./install.sh --role node --non-interactive \
#     --join-file /tmp/node-join.env \
#     --image-server-host 10.0.0.11 \
#     --pull-image-key root@10.0.0.11:/etc/gamepanel/keys/node-access \
#     --tls-insecure
#
# Installiert automatisch: SteamCMD, lib32, Java 21, MariaDB, Agent

GP_ROLE=node
GP_NON_INTERACTIVE=1
GAMEPANEL_SOURCE_DIR=/opt/gamepanel-src
GAMEPANEL_PANEL_URL=https://panel.example.com
GAMEPANEL_SETUP_TOKEN=
GAMEPANEL_PANEL_TLS_INSECURE=yes
IMAGE_SERVER_HOST=10.0.0.11
GAMEPANEL_IMAGE_KEY_FROM=root@10.0.0.11:/etc/gamepanel/keys/node-access
GAMEPANEL_NODE_IP=
GAMEPANEL_NODE_NAME=node-01

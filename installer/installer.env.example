# GamePanel Installer — Beispielkonfiguration (3-VM-Deployment)
# Siehe auch installer/examples/{panel,image-server,node}.env.example
#
# VM1 Panel      10.0.0.10  — install-panel.sh
# VM2 Images     10.0.0.11  — install-image-server.sh
# VM3 Game-Node  10.0.0.12  — install-node.sh

GP_ROLE=panel
GP_NON_INTERACTIVE=0

# --- Gemeinsam ---
GAMEPANEL_SOURCE_DIR=
# Repo-Pfad; Standard: Parent-Verzeichnis von installer/

# --- VM1 Panel ---
GAMEPANEL_PANEL_DIR=/opt/gamepanel
GAMEPANEL_PANEL_SYMLINK=no
GAMEPANEL_USE_PROD_COMPOSE=yes
GAMEPANEL_DEPLOY_USER=gamepanel
GAMEPANEL_PANEL_OVERWRITE_ENV=no

PANEL_DOMAIN=panel.example.com
APP_URL=https://panel.example.com
GAMEPANEL_URL=https://panel.example.com
PANEL_TLS=acme
ACME_EMAIL=admin@example.com
HTTP_PORT=80
HTTPS_PORT=443

POSTGRES_DB=gamepanel
POSTGRES_USER=gamepanel
# POSTGRES_PASSWORD=
# REDIS_PASSWORD=
# APP_KEY=
RUN_SEED=true

BACKEND_IMAGE=gamepanel-backend:local
FRONTEND_IMAGE=gamepanel-frontend:local

GAMEPANEL_ADMIN_EMAIL=admin@example.com
GAMEPANEL_ADMIN_PASSWORD=changeme
GAMEPANEL_ADMIN_NAME=Administrator

# Nach Panel-Install (automatisch gesetzt):
# GAMEPANEL_SETUP_TOKEN=

# --- VM2 Image-Server ---
IMAGE_SERVER_ROOT=/srv/gamepanel-images
IMAGE_SERVER_HOST=10.0.0.11
GAMEPANEL_IMAGE_SERVER_HOST=10.0.0.11
IMAGE_SERVER_USER=gamepanel-images
IMAGE_SERVER_GROUP=gamepanel-images
IMAGE_SERVER_ENABLE_FTPS=no
IMAGE_SERVER_FTP_BACKEND=sftp

# --- VM3 Game-Node ---
GAMEPANEL_NODE_USER=gamepanel-node
GAMEPANEL_NODE_NAME=node-01
GAMEPANEL_NODE_FQDN=node01.example.com
GAMEPANEL_NODE_HOSTNAME=node01
GAMEPANEL_NODE_IP=10.0.0.12
GAMEPANEL_PANEL_URL=https://panel.example.com
# GAMEPANEL_SETUP_TOKEN=   # von VM1
# GAMEPANEL_NODE_TOKEN=    # nach Registrierung automatisch
GAMEPANEL_IMAGE_SERVER_SSH_KEY=/etc/gamepanel/keys/image-server
GAMEPANEL_NODE_AGENT_URL=
GAMEPANEL_NODE_INSTALL_DOCKER=no
GAMEPANEL_NODE_SKIP_CGROUP_CHECK=no
GAMEPANEL_NODE_AGENT_PORT=9100

# --- All-in-One (optional) ---
STANDALONE_INSTALL_NODE=no

# --- Legacy / Worker ---
GAMEPANEL_WORKER_USER=gamepanel
